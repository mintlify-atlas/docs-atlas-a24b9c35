  "keyFeatures": [
    "Hierarchical registry system with custom ownership models",
    "Role-based access control with 32 resource-scoped roles",
    "Canonical ID system for mutable token IDs",
    "Universal resolver with wildcard and batch resolution",
    "ENSv1 to ENSv2 migration framework",
    "Gas-optimized ERC1155 singleton for subdomain NFTs",
    "DNS integration with DNSSEC support",
    "Cross-chain functionality and scalability"
  ],
